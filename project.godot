; Engine configuration file.
; Chaos of AI — Godot 4 (.NET/C#) project
; 상세 규칙은 CLAUDE.md / docs/ 참고. 이 파일은 Godot 에디터가 자동 갱신하므로
; 수동 편집 시 주석이 사라질 수 있음.

config_version=5

[application]

config/name="Chaos of AI"
config/description="폐허가 된 서울, 폭주한 AI에 맞서는 다크 액션 RPG (프롤로그 MVP)"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "C#", "Forward Plus")
config/icon="res://icon.svg"

[dotnet]

project/assembly_name="ChaosOfAI"

[autoload]

CombatFeedback="*res://scripts/combat/CombatFeedback.cs"
DamageNumberSpawner="*res://scripts/combat/DamageNumberSpawner.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

; 디아2식 조작: 좌클릭 = 이동/공격 지점. 스킬은 액션으로 매핑(모바일 터치 이식 대비).

click_move={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)
